<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="mupi_mobile_auth.ConnectMobileButtonInControlButtons"
       t-inherit="point_of_sale.ControlButtons"
       t-inherit-mode="extension"
       owl="1">

        <xpath expr="//button[1]" position="before">
            <button type="button"
                    class="control-button btn btn-light rounded-0 fw-bolder"
                    t-on-click="onClickConnectMobile">
                <i class="fa fa-mobile me-1"/>
                Connect Mobile
            </button>
        </xpath>

    </t>

</templates>