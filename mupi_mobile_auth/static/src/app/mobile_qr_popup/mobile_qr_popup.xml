<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="mupi_mobile_auth.MobileQrPopup">
        <Dialog title="'Connect Mobile'">
            <div class="text-center p-3">
                <img t-att-src="qrImage"
                     alt="Mobile QR Code"
                     style="width:250px;height:250px;"/>

                <div class="mt-2">
                    Expires:
                    <t t-esc="props.expiresAt"/>
                </div>
            </div>

            <t t-set-slot="footer">
                <button type="button"
                        class="btn btn-primary"
                        t-on-click="close">
                    Close
                </button>
            </t>
        </Dialog>
    </t>

</templates>