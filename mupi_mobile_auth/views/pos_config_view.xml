<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="pos_config_view_form_mobile_auth" model="ir.ui.view">
        <field name="name">pos.config.form.mobile.auth</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='module_pos_hr']" position="after">
                <field name="mupi_mobile_auth_base_url"
                       placeholder="http://192.168.1.2/odoo"/>
            </xpath>
        </field>
    </record>
</odoo>